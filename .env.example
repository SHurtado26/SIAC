# SIAC — Variables de entorno
# Copia este archivo como .env y rellena tus valores reales

# ── Proveedor de IA para el Chatbot (botón flotante) ──────────
# Si defines GROQ_API_KEY, OPENAI_API_KEY o GEMINI_API_KEY aquí, el
# chatbot la detecta automáticamente la primera vez que se abre, sin
# necesidad de pegarla en la interfaz.

# ── Groq (recomendado: gratis y muy rápido) ───────────────────
# Obtén tu key en: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=openai/gpt-oss-120b

# ── OpenAI (alternativa) ───────────────────────────────────────
# Obtén tu key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini (alternativa) ────────────────────────────────
# Obtén tu key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash
